# Copy to contracts/.env and fill in. NEVER commit the real .env (it is gitignored).

# RPC endpoint (a free-tier provider URL works fine).
#   Base Sepolia:       https://sepolia.base.org                  (chain 84532)
#   Robinhood testnet:  https://rpc.testnet.chain.robinhood.com   (chain 46630)
#   Robinhood mainnet:  https://rpc.mainnet.chain.robinhood.com   (chain 4663)
# For Robinhood, run SDK scripts with CHAIN=robinhood-testnet (see
# docs/ROBINHOOD-CHAIN-MIGRATION.md) or just use scripts/deploy-robinhood.sh.
RPC_URL=https://sepolia.base.org

# Deployer account. Use a THROWAWAY key for testnet only — never a real wallet.
DEPLOYER_ADDRESS=0xYourDeployerAddress
PRIVATE_KEY=0xYourThrowawayTestnetPrivateKey

# Optional: Basescan API key for `forge verify` (contract source verification).
# ETHERSCAN_API_KEY=
