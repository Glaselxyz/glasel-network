# Copy to contracts/.env and fill in. NEVER commit the real .env (it is gitignored).

# Base Sepolia RPC endpoint (a free-tier provider URL works fine).
RPC_URL=https://sepolia.base.org

# Deployer account. Use a THROWAWAY key for testnet only — never a real wallet.
DEPLOYER_ADDRESS=0xYourDeployerAddress
PRIVATE_KEY=0xYourThrowawayTestnetPrivateKey

# Optional: Basescan API key for `forge verify` (contract source verification).
# ETHERSCAN_API_KEY=
