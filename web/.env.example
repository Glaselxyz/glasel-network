# Glasel web app — faucet + status env.
# Copy to .env.local for local dev (gitignored), or set these in your host
# (Vercel → Project → Settings → Environment Variables). Root directory: web

# Faucet: a Base Sepolia key holding MINTER_ROLE on GlaselToken. SERVER-ONLY —
# never expose it. Without it, /api/faucet returns 503 and the page still builds.
# Grant the role from the admin/deployer: GlaselToken.grantRole(MINTER_ROLE, faucetAddr)
# and fund the address with ~0.02 Base Sepolia ETH for gas.
FAUCET_PRIVATE_KEY=

# Dedicated Base Sepolia RPC (recommended). Falls back to the public node.
# See docs/RPC.md.
RPC_URL=
# Optional: dedicated RPC for client-side reads (status page).
# NEXT_PUBLIC_RPC_URL=

# Faucet tuning (optional).
FAUCET_AMOUNT=5000
FAUCET_MAX_CLAIMS_PER_DAY=500
